<Application
    x:Class="Jampanion.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="NumericUpDown">
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
  </Application.Styles>
</Application>
