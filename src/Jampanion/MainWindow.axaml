<Window
    x:Class="Jampanion.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Jampanion.Controls"
    Title="Jampanion"
    Icon="avares://Jampanion/Assets/Jampanion.ico"
    Width="1280"
    Height="840"
    MinWidth="1040"
    MinHeight="620"
    UseLayoutRounding="True"
    Background="#EDF1F2"
    FontFamily="Segoe UI"
    FontSize="12.5">
  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#0B6E69" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#075A56" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#E5F3F1" />
    <SolidColorBrush x:Key="TextBrush" Color="#182329" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#647178" />
    <SolidColorBrush x:Key="LineBrush" Color="#D8E0E2" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SidebarBrush" Color="#F7F9F9" />
    <SolidColorBrush x:Key="ControlBrush" Color="#F2F5F5" />
    <SolidColorBrush x:Key="DangerBrush" Color="#B42318" />
    <SolidColorBrush x:Key="ReturnLimitBrush" Color="#D92D20" />
    <x:Double x:Key="HeaderSliderWidth">190</x:Double>
    <x:Double x:Key="HeaderValueWidth">36</x:Double>
    <x:Double x:Key="HeaderSliderGap">8</x:Double>
    <x:Double x:Key="HeaderSliderGroupWidth">234</x:Double>

    <DataTemplate x:Key="ChordSheetRowTemplate">
      <Grid ColumnDefinitions="50,*" MinHeight="{Binding RowHeight}">
        <!-- Double-click edits/adds the mark; right-click opens its style menu. -->
        <Border Grid.Column="0"
         Classes="rehearsalMarkArea"
         Background="Transparent"
         VerticalAlignment="Stretch"
                 Focusable="True"
                 PointerPressed="InlineRehearsalMarkArea_PointerPressed"
                 ToolTip.Tip="Double-click to edit or add a rehearsal mark in place; Enter saves, Escape cancels; right-click sets its style">
          <Grid>
            <StackPanel Width="46"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="0">
            <TextBlock IsVisible="{Binding HasSectionLabel}"
                       Text="{Binding SectionLabel}"
                       Foreground="{StaticResource AccentDarkBrush}"
                       FontWeight="Bold"
                       FontSize="{Binding SectionLabelFontSize}"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
            <TextBlock IsVisible="{Binding CanEditSectionStyle}"
                       Text="{Binding SectionStyleText}"
                       Foreground="{StaticResource MutedTextBrush}"
                       FontSize="8.5"
                       HorizontalAlignment="Center"
                       TextAlignment="Center"
                       TextWrapping="NoWrap" />
            </StackPanel>
          </Grid>
        </Border>
        <ItemsControl Grid.Column="1" ItemsSource="{Binding Cells}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <Grid
                  Width="{Binding FrameWidth}"
                  Height="{Binding CellHeight}"
                  Margin="3,2">
                <Border
                    Width="{Binding BarWidth}"
                    Height="{Binding CellHeight}"
                    Margin="{Binding LoopBarMargin}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="{Binding Background}"
                    BorderBrush="{Binding BorderBrush}"
                    BorderThickness="{Binding BorderThickness}"
                    CornerRadius="4"
                    ClipToBounds="False">
                <Grid>
                  <!-- Coda markers use the existing top/side whitespace; only
                       a jump marker narrows its cell's horizontal chord area.
                       The Ending marker uses the existing left gutter instead. -->
                  <ItemsControl ItemsSource="{Binding Chords}"
                                Margin="{Binding ChordItemsMargin}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate>
                          <Border
                              Width="{Binding Width}"
                              Background="{Binding Background}"
                              BorderBrush="#D8E0E2"
                              BorderThickness="0,0,1,0"
                              Focusable="True"
                              PointerPressed="InlineChordSymbol_PointerPressed"
                              ToolTip.Tip="Double-click to edit or insert a chord in place; Enter saves, Escape cancels">
                            <Grid>
                              <TextBlock
                                  Text="{Binding Symbol}"
                                  Foreground="{Binding Foreground}"
                                  FontWeight="{Binding FontWeight}"
                                  FontSize="{Binding FontSize}"
                                  HorizontalAlignment="Left"
                                  VerticalAlignment="Center"
                                  TextAlignment="Left"
                                  TextWrapping="NoWrap"
                                  TextTrimming="CharacterEllipsis"
                                  Margin="9,2,4,2" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                  </ItemsControl>
                  <Border
                      IsVisible="{Binding HasSectionTag}"
                      Background="{Binding SectionTagBackground}"
                      CornerRadius="3"
                      Padding="3,0"
                      Margin="4,2,0,0"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      IsHitTestVisible="False">
                    <TextBlock
                        Text="{Binding SectionTag}"
                        Foreground="{StaticResource AccentDarkBrush}"
                        FontWeight="Bold"
                        FontSize="8.5"
                        TextWrapping="NoWrap" />
                  </Border>
                  <Border
                      IsVisible="{Binding HasCodaStartMarker}"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Top"
                      Margin="{Binding CodaStartMarkerMargin}"
                      IsHitTestVisible="False"
                      ToolTip.Tip="Coda start">
                    <!-- Standard coda: a vertically elongated ring crossed by
                         a vertical stem and a horizontal bar. Keep this as
                         primitives so it is identical on every platform. -->
                    <Viewbox Width="{Binding CodaMarkerWidth}"
                             Height="{Binding CodaMarkerHeight}"
                             Stretch="Uniform">
                      <Grid Width="22" Height="24">
                      <Path
                          Data="M 11,4.5 A 6,7.5 0 1 0 11,19.5 A 6,7.5 0 1 0 11,4.5 M 11,1 L 11,23 M 1,12 L 21,12"
                          Stroke="{StaticResource AccentDarkBrush}"
                          StrokeThickness="2.2" />
                      </Grid>
                    </Viewbox>
                  </Border>
                  <Border
                      IsVisible="{Binding HasCodaMarker}"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="{Binding CodaMarkerMargin}"
                      IsHitTestVisible="False"
                      ToolTip.Tip="Coda jump">
                    <Viewbox Width="{Binding CodaMarkerWidth}"
                             Height="{Binding CodaMarkerHeight}"
                             Stretch="Uniform">
                      <Grid Width="22" Height="24">
                      <Path
                          Data="M 11,4.5 A 6,7.5 0 1 0 11,19.5 A 6,7.5 0 1 0 11,4.5 M 11,1 L 11,23 M 1,12 L 21,12"
                          Stroke="{StaticResource AccentDarkBrush}"
                          StrokeThickness="2.2" />
                      </Grid>
                    </Viewbox>
                  </Border>
                </Grid>
              </Border>
              <Grid
                  IsVisible="{Binding HasLoopStartMarker}"
                  Width="16"
                  Height="{Binding CellHeight}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  IsHitTestVisible="False">
                <Border
                    Width="2"
                    Height="{Binding CellHeight}"
                    HorizontalAlignment="Left"
                    Background="{StaticResource AccentDarkBrush}" />
                <Border
                    Width="2"
                    Height="{Binding CellHeight}"
                    Margin="3,0,0,0"
                    HorizontalAlignment="Left"
                    Background="{StaticResource AccentDarkBrush}" />
                <StackPanel
                    HorizontalAlignment="Left"
                    Margin="9,0,0,0"
                    VerticalAlignment="Center"
                    Spacing="5">
                  <Ellipse Width="4" Height="4" Fill="{StaticResource AccentDarkBrush}" />
                  <Ellipse Width="4" Height="4" Fill="{StaticResource AccentDarkBrush}" />
                </StackPanel>
              </Grid>
              <Grid
                  IsVisible="{Binding HasLoopEndMarker}"
                  Width="16"
                  Height="{Binding CellHeight}"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  IsHitTestVisible="False">
                <Border
                    Width="2"
                    Height="{Binding CellHeight}"
                    HorizontalAlignment="Right"
                    Background="{StaticResource AccentDarkBrush}" />
                <Border
                    Width="2"
                    Height="{Binding CellHeight}"
                    Margin="0,0,3,0"
                    HorizontalAlignment="Right"
                    Background="{StaticResource AccentDarkBrush}" />
                <StackPanel
                    HorizontalAlignment="Left"
                    Margin="4,0,0,0"
                    VerticalAlignment="Center"
                    Spacing="5">
                  <Ellipse Width="4" Height="4" Fill="{StaticResource AccentDarkBrush}" />
                  <Ellipse Width="4" Height="4" Fill="{StaticResource AccentDarkBrush}" />
                </StackPanel>
              </Grid>
            </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </DataTemplate>
  </Window.Resources>

  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="12,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#C8D2D4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="5" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#F0F5F4" />
      <Setter Property="BorderBrush" Value="#9FB4B2" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="MinHeight" Value="42" />
    </Style>
    <Style Selector="Button.headerPrimary">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="Button.primary:pointerover">
      <Setter Property="Background" Value="#11827B" />
      <Setter Property="BorderBrush" Value="#11827B" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pointerover /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="#11827B" />
      <Setter Property="BorderBrush" Value="#11827B" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pressed">
      <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.primary:pressed /template/ ContentPresenter#PART_ContentPresenter">
      <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentDarkBrush}" />
      <Setter Property="Foreground" Value="White" />
    </Style>
    <Style Selector="Button.danger">
      <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
      <Setter Property="BorderBrush" Value="#E4AAA4" />
    </Style>
    <Style Selector="Button.danger:pointerover">
      <Setter Property="Background" Value="#FEF3F2" />
      <Setter Property="BorderBrush" Value="#D92D20" />
    </Style>
    <Style Selector="Button.compact">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="10,0" />
      <Setter Property="FontSize" Value="11.5" />
    </Style>
    <Style Selector="Button.rehearsalMark">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="2,1" />
      <Setter Property="Margin" Value="1,0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.rehearsalMark:pointerover">
      <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#C8D2D4" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="AutoCompleteBox">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#AFC0C1" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="AutoCompleteBox:disabled">
      <Setter Property="Background" Value="#EEF1F2" />
      <Setter Property="BorderBrush" Value="#D4DDDE" />
      <Setter Property="Opacity" Value="0.68" />
    </Style>
    <Style Selector="NumericUpDown">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#C8D2D4" />
      <Setter Property="CornerRadius" Value="5" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="CheckBox">
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="ToggleSwitch">
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="Slider.headerSlider">
      <Setter Property="Height" Value="48" />
      <Setter Property="MinHeight" Value="48" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="ProgressBar.energy">
      <Setter Property="Height" Value="12" />
      <Setter Property="Background" Value="#DCE4E5" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="4" />
    </Style>
    <Style Selector="ProgressBar.recheckMarker">
      <Setter Property="Height" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Template">
        <ControlTemplate>
          <Grid Background="Transparent" ClipToBounds="True">
            <Border x:Name="PART_Indicator"
                    HorizontalAlignment="Left"
                    Background="Transparent"
                    BorderBrush="#F79009"
                    BorderThickness="0,0,3,0" />
          </Grid>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="ScrollBar">
      <Setter Property="AllowAutoHide" Value="False" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
    </Style>
    <Style Selector="ScrollBar:vertical">
      <Setter Property="Width" Value="6" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
      <Setter Property="Background" Value="#E1E8E9" />
      <Setter Property="Foreground" Value="#71878C" />
    </Style>
    <Style Selector="ScrollBar:vertical:pointerover">
      <Setter Property="Width" Value="6" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
    </Style>
    <Style Selector="ScrollBar:vertical:pressed">
      <Setter Property="Width" Value="6" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
    </Style>
    <Style Selector="ScrollBar:vertical:focus">
      <Setter Property="Width" Value="6" />
      <Setter Property="MinWidth" Value="6" />
      <Setter Property="MaxWidth" Value="6" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            Padding="16,12">
      <Grid ColumnSpacing="16"
            RowDefinitions="Auto,26,26">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="1.1*" MinWidth="200" />
          <ColumnDefinition Width="1.2*" MinWidth="234" />
          <ColumnDefinition Width="1*" MinWidth="180" />
          <ColumnDefinition Width="326" MinWidth="326" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.RowSpan="3" Spacing="2" VerticalAlignment="Center">
          <TextBlock Text="{Binding Title}"
                     FontSize="21"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding ArrangementStageText}"
                     FontSize="13.5"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AccentDarkBrush}"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding PlaybackStatusText}"
                     IsVisible="{Binding HasPlaybackStatus}"
                     FontSize="10.5"
                     Foreground="{StaticResource MutedTextBrush}"
                     TextTrimming="CharacterEllipsis" />
          <TextBlock Text="{Binding ThemeReturnStatusText}"
                     IsVisible="{Binding HasThemeReturnStatus}"
                     FontSize="10.5"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource AccentDarkBrush}"
                     TextTrimming="CharacterEllipsis" />
        </StackPanel>

        <Grid Grid.Column="1"
              Grid.RowSpan="3"
              RowDefinitions="Auto,26,26"
              VerticalAlignment="Stretch">
          <Grid ColumnDefinitions="*,Auto"
                ColumnSpacing="{StaticResource HeaderSliderGap}"
                Width="{StaticResource HeaderSliderGroupWidth}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center">
            <TextBlock Classes="sectionTitle" Text="Theme Return" VerticalAlignment="Center" />
            <Grid Grid.Column="1"
                  ColumnDefinitions="Auto,66"
                  ColumnSpacing="{StaticResource HeaderSliderGap}"
                  Margin="0,0,18,0"
                  VerticalAlignment="Center">
              <TextBlock Text="{Binding ThemeReturnModeText}"
                         VerticalAlignment="Center"
                         FontSize="10.5"
                         Foreground="{StaticResource MutedTextBrush}"
                         Margin="0,1,0,0" />
              <ToggleSwitch Grid.Column="1"
                            IsChecked="{Binding AutomaticThemeReturnEnabled}"
                            Focusable="False"
                            Width="66"
                            MinWidth="66"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            OnContent=""
                            OffContent="" />
            </Grid>
          </Grid>
          <Grid Grid.Row="1"
                Grid.RowSpan="2"
                RowDefinitions="48"
                ColumnSpacing="{StaticResource HeaderSliderGap}"
                Width="{StaticResource HeaderSliderGroupWidth}"
                HorizontalAlignment="Left"
                VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="190" />
              <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <Slider Classes="headerSlider"
                    Value="{Binding ThemeReturnSensitivity}"
                    Minimum="0"
                    Maximum="100"
                    TickFrequency="5"
                    Width="{StaticResource HeaderSliderWidth}"
                    IsEnabled="{Binding AutomaticThemeReturnEnabled}" />
            <TextBlock Grid.Column="1"
                       Text="{Binding ThemeReturnSensitivity, StringFormat={}{0:0}%}"
                       Width="{StaticResource HeaderValueWidth}"
                       HorizontalAlignment="Right"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       FontSize="10.5"
                       IsEnabled="{Binding AutomaticThemeReturnEnabled}" />
          </Grid>
        </Grid>

        <Grid Grid.Column="2"
              Grid.RowSpan="3"
              RowDefinitions="Auto,16,16"
              ColumnDefinitions="56,*"
              RowSpacing="6"
              ColumnSpacing="8"
              VerticalAlignment="Center">
          <TextBlock Grid.Row="0"
                     Grid.ColumnSpan="2"
                     Classes="sectionTitle"
                     Text="Energy"
                     VerticalAlignment="Center"
                     Margin="0,-6,0,6" />
          <TextBlock Grid.Row="1"
                     Text="Reference"
                     FontSize="10.5"
                     Foreground="{StaticResource MutedTextBrush}"
                     VerticalAlignment="Center"
                     Margin="0,-10,0,10" />
          <Border Grid.Row="1" Grid.Column="1"
                  Height="12"
                  Background="#DCE4E5"
                  CornerRadius="4"
                  ClipToBounds="True"
                  VerticalAlignment="Center"
                  Margin="0,-10,0,10">
            <Grid>
              <ProgressBar Classes="energy"
                           Value="{Binding ReferenceEnergyPercent}"
                           Minimum="0"
                           Maximum="100"
                           Background="Transparent" />
              <ProgressBar Classes="energy"
                           Value="{Binding ReturnThresholdPercent}"
                           Minimum="0"
                           Maximum="100"
                           Foreground="{StaticResource ReturnLimitBrush}"
                           Background="Transparent" />
              <ProgressBar Classes="recheckMarker"
                           Value="{Binding CancellationThresholdPercent}"
                           Minimum="0"
                           Maximum="100"
                           IsVisible="{Binding IsHeadOutRecheckActive}" />
            </Grid>
          </Border>
          <TextBlock Grid.Row="2"
                     Text="Current"
                     FontSize="10.5"
                     Foreground="{StaticResource MutedTextBrush}"
                     VerticalAlignment="Center"
                     Margin="0,-10,0,10" />
          <Border Grid.Row="2" Grid.Column="1"
                  Height="12"
                  Background="#DCE4E5"
                  CornerRadius="4"
                  ClipToBounds="True"
                  VerticalAlignment="Center"
                  Margin="0,-10,0,10">
            <ProgressBar Classes="energy"
                         Value="{Binding EndingEnergyPercent}"
                         Minimum="0"
                         Maximum="100"
                         Background="Transparent" />
          </Border>
        </Grid>

        <Grid Grid.Column="3"
              Grid.RowSpan="3"
              ColumnDefinitions="126,58,58,54"
              ColumnSpacing="10"
              Width="326"
              HorizontalAlignment="Left"
              VerticalAlignment="Center">
          <Button Classes="primary headerPrimary"
                  Command="{Binding StartSessionCommand}"
                  Width="126"
                  HorizontalAlignment="Left"
                  Padding="8,0">
            <TextBlock Text="{Binding PrimarySessionButtonText}"
                       HorizontalAlignment="Stretch"
                       TextAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       Foreground="White" />
          </Button>
          <Button Grid.Column="1"
                  Command="{Binding StopSessionCommand}"
                  IsEnabled="{Binding IsSessionRunning}"
                  Width="58"
                  HorizontalAlignment="Left"
                  Padding="6,0"
                  FontSize="11.5"
                  Content="Stop" />
          <Button Grid.Column="2"
                  Classes="danger"
                  Command="{Binding PanicCommand}"
                  IsEnabled="{Binding PortsOpen}"
                  Width="58"
                  HorizontalAlignment="Left"
                  Padding="6,0"
                  FontSize="11.5"
                  Content="Panic" />
          <Button Grid.Column="3"
                  Click="OpenSettingsButton_Click"
                  Width="54"
                  MinWidth="54"
                  HorizontalAlignment="Left"
                  Padding="0"
                  ToolTip.Tip="Settings">
            <PathIcon Width="18"
                      Height="18"
                      Data="M19.43,12.98c0.04,-0.32 0.07,-0.65 0.07,-0.98s-0.02,-0.66 -0.07,-0.98l2.11,-1.65c0.19,-0.15 0.24,-0.42 0.12,-0.64l-2,-3.46c-0.12,-0.22 -0.37,-0.31 -0.6,-0.22l-2.49,1c-0.52,-0.4 -1.08,-0.73 -1.69,-0.98L14.5,2.42C14.47,2.18 14.25,2 14,2h-4c-0.25,0 -0.46,0.18 -0.5,0.42L9.12,5.07c-0.61,0.25 -1.17,0.59 -1.69,0.98l-2.49,-1c-0.23,-0.08 -0.48,0 -0.6,0.22l-2,3.46c-0.13,0.22 -0.07,0.49 0.12,0.64l2.11,1.65c-0.04,0.32 -0.08,0.65 -0.08,0.98s0.03,0.66 0.08,0.98l-2.11,1.65c-0.19,0.15 -0.24,0.42 -0.12,0.64l2,3.46c0.12,0.22 0.37,0.31 0.6,0.22l2.49,-1c0.52,0.4 1.08,0.73 1.69,0.98l0.38,2.65c0.04,0.24 0.25,0.42 0.5,0.42h4c0.25,0 0.46,-0.18 0.5,-0.42l0.38,-2.65c0.61,-0.25 1.17,-0.58 1.69,-0.98l2.49,1c0.23,0.08 0.48,0 0.6,-0.22l2,-3.46c0.12,-0.22 0.07,-0.49 -0.12,-0.64l-2.11,-1.65z M12,15.5A3.5,3.5 0,1 1,12,8a3.5,3.5 0,0 1,0,7.5z"
                      Foreground="{StaticResource TextBrush}" />
          </Button>
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="252,*">
      <Border Background="{StaticResource SidebarBrush}"
              BorderBrush="{StaticResource LineBrush}"
              BorderThickness="0,0,1,0">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border BorderBrush="{StaticResource LineBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,0">
              <StackPanel Spacing="11">
                <Grid Height="52"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="8"
                      VerticalAlignment="Center">
                  <TextBlock Classes="sectionTitle" Text="Song" VerticalAlignment="Center" />
                  <Button Grid.Column="1"
                          Classes="compact"
                          Command="{Binding SaveSongCommand}"
                          IsEnabled="{Binding IsSongSaveEnabled}"
                          MinWidth="56"
                          VerticalAlignment="Center"
                          Content="Save" />
                </Grid>

                <AutoCompleteBox x:Name="TitleSearchBox"
                                 ItemsSource="{Binding Tunes}"
                                 SelectedItem="{Binding SelectedTune}"
                                 FilterMode="Contains"
                                 MinimumPrefixLength="0"
                                 MinimumPopulateDelay="0"
                                 IsTextCompletionEnabled="False"
                                 IsEnabled="{Binding IsSongSelectionEnabled}"
                                 PlaceholderText="Search songs"
                                 GotFocus="TitleSearchBox_GotFocus"
                                 PointerPressed="TitleSearchBox_PointerPressed"
                                 SelectionChanged="TitleSearchBox_SelectionChanged">
                  <AutoCompleteBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Title}" />
                    </DataTemplate>
                  </AutoCompleteBox.ItemTemplate>
                </AutoCompleteBox>

                <Grid ColumnDefinitions="*,80" ColumnSpacing="10">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="label" Text="Tempo" />
                    <NumericUpDown Value="{Binding TempoBpm}"
                                   Minimum="40"
                                   Maximum="300"
                                   Increment="5" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="label" Text="Meter" />
                    <Border Height="36"
                            Background="{StaticResource ControlBrush}"
                            BorderBrush="{StaticResource LineBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="10,0">
                      <TextBlock Text="{Binding TimeSignatureText}"
                                 FontWeight="SemiBold"
                                 VerticalAlignment="Center" />
                    </Border>
                  </StackPanel>
                </Grid>

                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Style" />
                  <ComboBox ItemsSource="{Binding StyleOptions}"
                            SelectedItem="{Binding SelectedStyleOption}"
                            SelectionChanged="StyleComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                  <TextBlock Text="{Binding StyleStatusText}"
                             MinHeight="30"
                             FontSize="10.5"
                             Foreground="{StaticResource MutedTextBrush}"
                             TextWrapping="Wrap" />
                </StackPanel>

                <Grid ColumnDefinitions="92,*" ColumnSpacing="10">
                  <StackPanel Spacing="4">
                    <TextBlock Classes="label" Text="Key" />
                    <ComboBox ItemsSource="{Binding KeyOptions}"
                              SelectedItem="{Binding SelectedKeyOption}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                  <StackPanel Grid.Column="1" Spacing="4">
                    <TextBlock Classes="label" Text="Accidentals" />
                    <ComboBox ItemsSource="{Binding AccidentalOptions}"
                              SelectedItem="{Binding SelectedAccidentalOption}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </StackPanel>
                </Grid>

                <TextBlock FontSize="10.5"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap">
                  <Run Text="Original key " />
                  <Run Text="{Binding DefaultKeyText}" FontWeight="SemiBold" />
                  <Run Text=" · " />
                  <Run Text="{Binding FormText}" />
                </TextBlock>
              </StackPanel>
            </Border>

            <Border Padding="16,16,16,18">
              <StackPanel Spacing="10">
                <TextBlock Classes="sectionTitle" Text="Mix" />
                <Grid ColumnDefinitions="78,*,34"
                      RowDefinitions="38,38,38,38"
                      ColumnSpacing="8">
                  <CheckBox IsChecked="{Binding PianoEnabled}" Content="Piano" VerticalAlignment="Center" />
                  <controls:VolumeSlider Grid.Column="1" Value="{Binding PianoVolume, Mode=TwoWay}" VerticalAlignment="Center" />
                  <TextBlock Grid.Column="2" Text="{Binding PianoVolume, StringFormat={}{0:0}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />

                  <CheckBox Grid.Row="1" IsChecked="{Binding BassEnabled}" Content="Bass" VerticalAlignment="Center" />
                  <controls:VolumeSlider Grid.Row="1" Grid.Column="1" Value="{Binding BassVolume, Mode=TwoWay}" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding BassVolume, StringFormat={}{0:0}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />

                  <CheckBox Grid.Row="2" IsChecked="{Binding DrumsEnabled}" Content="Drums" VerticalAlignment="Center" />
                  <controls:VolumeSlider Grid.Row="2" Grid.Column="1" Value="{Binding DrumsVolume, Mode=TwoWay}" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding DrumsVolume, StringFormat={}{0:0}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />

                  <CheckBox Grid.Row="3" IsChecked="{Binding MidiThruEnabled}" Content="MIDI thru" VerticalAlignment="Center" />
                  <controls:VolumeSlider Grid.Row="3" Grid.Column="1" Value="{Binding VibraphoneVolume, Mode=TwoWay}" VerticalAlignment="Center" />
                  <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding VibraphoneVolume, StringFormat={}{0:0}}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10.5" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Border>

      <Grid Grid.Column="1"
            RowDefinitions="52,*"
            Background="{StaticResource PanelBrush}">
        <Border BorderBrush="{StaticResource LineBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,0">
          <Grid ColumnSpacing="{StaticResource HeaderSliderGap}"
                VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="190" />
              <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBlock Classes="sectionTitle" Text="Chord Sheet" VerticalAlignment="Center" />
            <Button Grid.Column="1"
                    Classes="compact"
                    Command="{Binding SaveChartCommand}"
                    IsEnabled="{Binding IsChartSaveEnabled}"
                    MinWidth="56"
                    Content="Save" />
            <TextBlock Grid.Column="3"
                       Classes="label"
                       Text="Scale"
                       VerticalAlignment="Center"
                       Margin="0,3,0,0" />
            <Slider Grid.Column="4"
                    Classes="headerSlider"
                    Value="{Binding ChordSheetScaleSliderPosition, Mode=TwoWay}"
                    Minimum="0"
                    Maximum="9"
                    Width="{StaticResource HeaderSliderWidth}" />
            <TextBlock Grid.Column="5"
                       Classes="label"
                       Text="{Binding ChordSheetScaleText}"
                       Width="{StaticResource HeaderValueWidth}"
                       HorizontalAlignment="Right"
                       TextAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,3,0,0" />
          </Grid>
        </Border>

        <ScrollViewer Grid.Row="1"
                      x:Name="ChordSheetScrollViewer"
                      Background="White"
                      Padding="16,14,16,20"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Visible"
                      SizeChanged="ChordSheetScrollViewer_SizeChanged">
          <StackPanel Spacing="14">
            <ItemsControl ItemsSource="{Binding ChordRows}" ItemTemplate="{StaticResource ChordSheetRowTemplate}" />
            <StackPanel IsVisible="{Binding ShowCodaPreview}" Spacing="0" Margin="0,12,0,0">
              <ItemsControl ItemsSource="{Binding CodaRows}" ItemTemplate="{StaticResource ChordSheetRowTemplate}" />
            </StackPanel>
            <Border Height="48" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
