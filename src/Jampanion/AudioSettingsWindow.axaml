<!-- Segoe UI is not installed on macOS; use a shared font so text
     baselines do not shift between desktop platforms. -->
<Window
    x:Class="Jampanion.AudioSettingsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    Width="620"
    Height="680"
    MinWidth="540"
    MinHeight="560"
    CanResize="True"
    UseLayoutRounding="True"
    Background="#EDF1F2"
    FontFamily="Arial"
    FontSize="12.5">
  <Window.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#0B6E69" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#075A56" />
    <SolidColorBrush x:Key="TextBrush" Color="#182329" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#647178" />
    <SolidColorBrush x:Key="LineBrush" Color="#D8E0E2" />
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="ControlBrush" Color="#F2F5F5" />
  </Window.Resources>
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="TextBlock.label">
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
    </Style>
    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Background" Value="White" />
      <Setter Property="BorderBrush" Value="#C8D2D4" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="FontSize" Value="12.5" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="14,0" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Background" Value="White" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="BorderBrush" Value="#C8D2D4" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button:pointerover">
      <Setter Property="Background" Value="#F0F5F4" />
      <Setter Property="BorderBrush" Value="#9FB4B2" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="Auto,*,Auto">
    <Border Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,0,0,1"
            Padding="22,18">
      <StackPanel Spacing="3">
        <TextBlock Text="Settings" FontSize="22" FontWeight="SemiBold" />
        <TextBlock Text="MIDI, song library, and audio"
                   FontSize="11"
                   Foreground="{StaticResource MutedTextBrush}" />
      </StackPanel>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel Margin="20" Spacing="14">
        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="12">
            <TextBlock Classes="sectionTitle" Text="MIDI" />
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Input" />
              <ComboBox ItemsSource="{Binding InputPorts}"
                        SelectedItem="{Binding SelectedInputPort, Mode=TwoWay}" />
            </StackPanel>
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Output" />
              <ComboBox ItemsSource="{Binding OutputPorts}"
                        SelectedItem="{Binding SelectedOutputPort, Mode=TwoWay}" />
            </StackPanel>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
              <TextBlock Text="MIDI thru routes the selected input to the Vibraphone mix channel."
                         FontSize="10.5"
                         Foreground="{StaticResource MutedTextBrush}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center" />
              <Button Grid.Column="1"
                      Command="{Binding RefreshDevicesCommand}"
                      Content="Refresh devices"
                      MinWidth="124" />
            </Grid>
          </StackPanel>
        </Border>

        <Border IsVisible="{Binding IsAsioSettingsVisible}"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="12">
            <TextBlock Classes="sectionTitle" Text="Windows Audio" />
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Audio backend" />
              <ComboBox ItemsSource="{Binding WindowsAudioBackendOptions}"
                        SelectedItem="{Binding SelectedWindowsAudioBackendOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
            <StackPanel IsEnabled="{Binding IsAsioBackendSelected}" Spacing="12">
              <StackPanel Spacing="4">
                <TextBlock Classes="label" Text="ASIO driver and output device" />
                <ComboBox ItemsSource="{Binding AsioDriverOptions}"
                          SelectedItem="{Binding SelectedAsioDriverOption, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <StackPanel Spacing="4">
                <TextBlock Classes="label" Text="ASIO output channels" />
                <ComboBox ItemsSource="{Binding AsioOutputChannelOptions}"
                          SelectedItem="{Binding SelectedAsioOutputChannelOption, Mode=TwoWay}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </StackPanel>
              <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <StackPanel Spacing="4">
                  <TextBlock Classes="label" Text="Sample rate" />
                  <ComboBox ItemsSource="{Binding AsioSampleRateOptions}"
                            SelectedItem="{Binding SelectedAsioSampleRateOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="4">
                  <TextBlock Classes="label" Text="Buffer" />
                  <ComboBox ItemsSource="{Binding AsioBufferSizeOptions}"
                            SelectedItem="{Binding SelectedAsioBufferSizeOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate><TextBlock Text="{Binding DisplayName}" /></DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </Grid>
            </StackPanel>
            <TextBlock Text="Automatic tries ASIO first and falls back to WinMM. Changing an audio setting restarts the built-in output."
                       FontSize="10.5"
                       Foreground="{StaticResource MutedTextBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="18">
          <StackPanel Spacing="12">
            <TextBlock Classes="sectionTitle" Text="Song Library" />
            <StackPanel Spacing="4">
              <TextBlock Classes="label" Text="Folder" />
              <Border Background="{StaticResource ControlBrush}"
                      BorderBrush="{StaticResource LineBrush}"
                      BorderThickness="1"
                      CornerRadius="6"
                      Padding="11,9">
                <TextBlock Text="{Binding SongLibraryText}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis"
                           MaxHeight="36"
                           ToolTip.Tip="{Binding SongLibraryText}" />
              </Border>
            </StackPanel>
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
              <Button Click="ImportIRealProButton_Click"
                      IsEnabled="{Binding IsSongSelectionEnabled}"
                      Content="Import iReal Pro" />
              <Button Grid.Column="1"
                      Command="{Binding RefreshSongsCommand}"
                      IsEnabled="{Binding IsSongSelectionEnabled}"
                      Content="Refresh library" />
              <Button Grid.Column="2"
                      Click="SelectSongLibraryFolderButton_Click"
                      IsEnabled="{Binding IsSongSelectionEnabled}"
                      Content="Choose folder" />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource LineBrush}"
            BorderThickness="0,1,0,0"
            Padding="20,12">
      <Grid ColumnDefinitions="*,Auto" ColumnSpacing="16">
        <TextBlock Text="{Binding StatusText}"
                   FontSize="10.5"
                   Foreground="{StaticResource MutedTextBrush}"
                   TextTrimming="CharacterEllipsis"
                   VerticalAlignment="Center" />
        <Button Grid.Column="1"
                HorizontalAlignment="Right"
                Click="CloseButton_Click"
                Content="Close"
                MinWidth="90" />
      </Grid>
    </Border>
  </Grid>
</Window>
